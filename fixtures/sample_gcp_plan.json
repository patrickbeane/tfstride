          "provider_name": "registry.terraform.io/hashicorp/google",
          "values": {
            "name": "tfstride-app",
            "ip_cidr_range": "10.10.1.0/24",
            "region": "us-central1",
            "network": "google_compute_network.main.id"
          }
        },
        {
          "address": "google_compute_firewall.public_ssh",
          "mode": "managed",
          "type": "google_compute_firewall",
