{
  "format_version": "1.2",
  "terraform_version": "1.8.5",
  "planned_values": {
    "root_module": {
      "resources": [
        {
          "address": "google_compute_network.main",
          "mode": "managed",
          "type": "google_compute_network",
          "name": "main",
          "provider_name": "registry.terraform.io/hashicorp/google",
          "values": {
            "name": "tfstride-main",
